rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Profile
    match /users/{userId} {
      function isValidUser(data) {
        return data.userId == request.auth.uid 
          && data.email is string && data.email.size() <= 256;
      }
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL']);

      // Watch History
      match /watchHistory/{animeId} {
        function isValidHistory(data) {
          return data.animeId is string && data.title is string && data.episodeNumber is number;
        }
        allow list, get: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidHistory(request.resource.data);
        allow delete: if isOwner(userId);
      }

      // Movie/TV Watch History
      match /movieWatchHistory/{movieId} {
        function isValidMovieHistory(data) {
          return data.movieId is string && data.title is string && data.mediaType is string;
        }
        allow list, get: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidMovieHistory(request.resource.data);
        allow delete: if isOwner(userId);
      }

      // Anime Watch List
      match /watchlist/{itemId} {
        function isValidWatchlist(data) {
          return data.title is string && data.poster is string && data.mediaType is string;
        }
        allow list, get: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidWatchlist(request.resource.data);
        allow delete: if isOwner(userId);
      }

      // Movie/TV Watch List
      match /movieWatchlist/{itemId} {
        function isValidMovieWatchlist(data) {
          return data.title is string && data.poster is string && data.mediaType is string;
        }
        allow list, get: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidMovieWatchlist(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
